# Supabase PostgreSQL Connection Details
# Use the "Transaction Connection String" from Supabase Settings > Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-DB-HOST]:6543/postgres?pgbouncer=true

# Supabase API Credentials
# Used to upload images to Supabase Storage
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-PUBLIC-KEY]

# Server Port (Default is 5000)
PORT=5000
